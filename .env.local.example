# ============================================
# SUPABASE (Get these from your Supabase dashboard)
# Project Settings > API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# GOOGLE MAPS (Get from Google Cloud Console)
# APIs & Services > Credentials
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# ============================================
# STRIPE (Get from Stripe Dashboard)
# We'll set these up in Week 7-8
# ============================================
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SpotShare
